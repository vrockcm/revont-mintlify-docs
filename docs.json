{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Revont",
  "description": "AI Call Assistant for Sales — real-time guidance, automatic summaries, and CRM sync for every call.",
  "colors": {
    "primary": "#ffffff",
    "light": "#ffffff",
    "dark": "#ffffff"
  },
  "favicon": {
    "light": "/images/Revont_RevontBlack.svg",
    "dark": "/images/Revont_RevontWhite.svg"
  },
  "icons": {
    "library": "fontawesome"
  },
  "styling": {
    "eyebrows": "section"
  },
  "contextual": {
    "options": ["copy", "view", "assistant"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "core-concepts"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/workspace-setup",
              "platform/user-management",
              "platform/roles-permissions"
            ]
          },
          {
            "group": "AI Assistant",
            "pages": [
              "assistant/live-call-guidance",
              "assistant/call-summaries",
              "assistant/action-items",
              "assistant/playbooks"
            ]
          },
          {
            "group": "Analytics",
            "pages": [
              "analytics/call-analytics",
              "analytics/team-performance",
              "analytics/dashboards"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/crm",
              "integrations/calendar",
              "integrations/video-conferencing",
              "integrations/webhooks"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api/overview",
              "api/authentication"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api/calls",
              "api/summaries",
              "api/contacts",
              "api/webhooks"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Go to App",
      "href": "https://app.revont.ai"
    }
  },
  "footer": {
    "socials": {
      "instagram": "https://www.instagram.com/revont.ai"
    }
  },
  "logo": {
    "light": "/images/Revont_RevontLogoBlack.png",
    "dark": "/images/Revont_RevontLogoWhite.png",
    "href": "https://revont.ai"
  },
  "background": {
    "color": {
      "light": "#121212",
      "dark": "#121212"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "fonts": {
    "family": "Inter"
  }
}
