        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api/overview",
              "api/authentication"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api/calls",
              "api/summaries",
              "api/contacts",
              "api/webhooks"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [],
