  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "core-concepts"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/workspace-setup",
              "platform/user-management",
              "platform/roles-permissions"
            ]
          },
          {
            "group": "AI Assistant",
            "pages": [
              "assistant/live-call-guidance",
              "assistant/call-summaries",
              "assistant/action-items",
              "assistant/playbooks"
            ]
          },
          {
            "group": "Analytics",
            "pages": [
              "analytics/call-analytics",
              "analytics/team-performance",
              "analytics/dashboards"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/crm",
              "integrations/calendar",
              "integrations/video-conferencing",
              "integrations/webhooks"
